#!/bin/sh
# Professional Init - Security Audit Core
DB="/var/proinit/config/integrity.db"

printf "\033[0;36m[Security] Verifying system integrity...\033[0m "

if [ ! -f "$DB" ]; then
    mkdir -p /var/proinit/config
    sha256sum /sbin/init /var/proinit/bin/* > "$DB"
    printf "[\033[0;32mDB CREATED\033[0m]\n"
else
    sha256sum -c "$DB" > /dev/null 2>&1
    if [ $? -eq 0 ]; then
        printf "[\033[0;32mOK\033[0m]\n"
    else
        printf "[\033[0;31mFAILED\033[0m]\n"
        printf "WARNING: Unauthorized changes detected in core binaries!\n" > /dev/kmsg
    fi
fi
